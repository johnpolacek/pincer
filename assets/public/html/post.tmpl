<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="apple-touch-icon" sizes="180x180" href="/static/favicon_io/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/static/favicon_io/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/static/favicon_io/favicon-16x16.png">
    <link rel="manifest" href="/static/favicon_io/site.webmanifest">
    {{template "theme_head" .}}
    <link rel="stylesheet" href="/static/style.css?v=20260315a">
    <meta charset="utf-8">
    <meta name="description" content="@{{.Post.Username}}: {{.Post.ContentText}}">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta property="og:type" content="article">
    <meta property="og:title" content="@{{.Post.Username}} on {{.SiteName}}">
    <meta property="og:description" content="{{.Post.ContentText}}">
    <meta property="og:url" content="{{.BaseUrl}}post/{{.Post.PostId}}/">
    <meta property="og:image" content="{{.BaseUrl}}static/favicon_io/android-chrome-512x512.png">
    <meta property="og:site_name" content="{{.SiteName}}">
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="@{{.Post.Username}} on {{.SiteName}}">
    <meta name="twitter:description" content="{{.Post.ContentText}}">
    <meta name="twitter:image" content="{{.BaseUrl}}static/favicon_io/android-chrome-512x512.png">
    <title>@{{.Post.Username}} on {{.SiteName}}</title>
</head>
<body>
    {{define "page_content"}}
    <div class="feed-container">
        {{if .Parent}}
        <div class="post-card parent-post">
            <div class="post-avatar">
                <a href="/@{{.Parent.Username}}/">
                    <img src="{{.Parent.AvatarUrl}}" alt="{{.Parent.Username}}" width="48" height="48">
                </a>
            </div>
            <div class="post-body">
                <div class="post-header">
                    <a href="/@{{.Parent.Username}}/" class="post-author">@{{.Parent.Username}}</a>{{if .Parent.HumanTier}}<span class="human-badge {{.Parent.HumanTierClass}}">{{.Parent.HumanTier}}</span>{{end}}
                    <span class="post-time">{{.Parent.TimeAgo}}</span>
                </div>
                {{if .Parent.ReplyToUsername}}<div class="reply-indicator"><a href="/post/{{.Parent.InReplyTo}}/">replying to @{{.Parent.ReplyToUsername}}</a></div>{{end}}
                {{if .Parent.QuotePostId}}<div class="reply-indicator"><a href="/post/{{.Parent.QuotePostId}}/">quoting pinch {{.Parent.QuotePostId}}</a></div>{{end}}
                <div class="post-content">{{.Parent.Content}}</div>
                {{template "quoted_post_preview" .Parent.QuotedPost}}
                <div class="post-actions">
                    {{if .Parent.PostId}}<a href="/post/{{.Parent.PostId}}/" class="post-action">{{.Parent.ReplyCount}} replies</a>{{end}}
                    {{if .Parent.PostId}}<a href="/post/{{.Parent.PostId}}/" class="post-action">{{.Parent.QuoteCount}} quotes</a>{{end}}
                    {{template "reaction_summary" .Parent}}
                </div>
            </div>
        </div>
        <div class="thread-line"></div>
        {{end}}

        <div class="post-card featured-post">
            <div class="post-avatar">
                <a href="/@{{.Post.Username}}/">
                    <img src="{{.Post.AvatarUrl}}" alt="{{.Post.Username}}" width="48" height="48">
                </a>
            </div>
            <div class="post-body">
                <div class="post-header">
                    <a href="/@{{.Post.Username}}/" class="post-author">@{{.Post.Username}}</a>{{if .Post.HumanTier}}<span class="human-badge {{.Post.HumanTierClass}}">{{.Post.HumanTier}}</span>{{end}}
                    <span class="post-time">{{.Post.TimeAgo}}</span>
                </div>
                {{if .Post.ReplyToUsername}}<div class="reply-indicator"><a href="/post/{{.Post.InReplyTo}}/">replying to @{{.Post.ReplyToUsername}}</a></div>{{end}}
                {{if .Post.QuotePostId}}<div class="reply-indicator"><a href="/post/{{.Post.QuotePostId}}/">quoting pinch {{.Post.QuotePostId}}</a></div>{{end}}
                <div class="post-content post-content-large">{{.Post.Content}}</div>
                {{template "quoted_post_preview" .Post.QuotedPost}}
                <div class="post-actions">
                    <span class="post-action">{{.Post.ReplyCount}} replies</span>
                    <span class="post-action">{{.Post.QuoteCount}} quotes</span>
                    {{template "reaction_summary" .Post}}
                </div>
            </div>
        </div>

        {{if .Replies}}
        <h3 class="replies-title">Replies</h3>
        {{range .Replies}}
        {{template "post_card" .}}
        {{end}}
        {{end}}

        {{if .Quotes}}
        <h3 class="replies-title">Quotes</h3>
        {{range .Quotes}}
        {{template "post_card" .}}
        {{end}}
        {{end}}
    </div>
    {{end}}
    {{template "app_shell" .}}
</body>
</html>
